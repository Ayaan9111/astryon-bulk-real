modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
MODEL_PROVIDER = "groq"
AI_MODEL_NAME = "llama-3.3-70b-versatile"
STARTER_PROVIDER = "groq"
PRO_PROVIDER = "groq"
AGENCY_PROVIDER = "groq"
VITE_PADDLE_CLIENT_TOKEN = "live_0897f18d913f33083c45cd68ec1"
PADDLE_PRODUCT_STARTER = "pri_01knrwepzjjaqzr9v8wvtf4azp"
PADDLE_PRODUCT_PRO = "pri_01knrwq2v3vg7vb2gtmebfbb3s"
PADDLE_PRODUCT_AGENCY = "pri_01knrx4545jmdw257v1jjf1k4v"

[nix]
channel = "stable-25_05"
